    "node-sql-parser": "^5.4.0",
    "open": "^10.1.0",
    "openai": "^4.85.2",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^10.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.1.0",
