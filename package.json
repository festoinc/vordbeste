{
  "name": "vordbeste",
  "version": "0.3.7",
  "description": "Talk to your database in plain English",
  "keywords": [
    "database",
    "ai",
    "sql",
    "natural-language",
    "cli",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/festoinc/vordbeste.git"
  },
  "homepage": "https://github.com/festoinc/vordbeste#readme",
  "bugs": {
    "url": "https://github.com/festoinc/vordbeste/issues"
  },
  "bin": {
    "vordbeste": "bin/vordbeste.js"
  },
